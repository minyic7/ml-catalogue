{
  "name": "ml-catalogue",
  "private": true,
  "scripts": {
    "dev": "concurrently -n frontend,backend -c cyan,magenta \"pnpm dev:frontend\" \"pnpm dev:backend\"",
    "dev:frontend": "pnpm --filter frontend dev",
    "dev:backend": "cd backend && uv run uvicorn app.main:app --reload",
    "lint": "pnpm lint:frontend && pnpm lint:backend",
    "lint:frontend": "pnpm --filter frontend lint",
    "lint:backend": "cd backend && uv run ruff check .",
    "format": "pnpm format:frontend && pnpm format:backend",
    "format:frontend": "pnpm --filter frontend exec prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css}\"",
    "format:backend": "cd backend && uv run ruff format ."
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
